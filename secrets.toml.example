# ─────────────────────────────────────────────────────────────
# Archivo: .streamlit/secrets.toml
#
# Este archivo NO se sube a GitHub (añádelo al .gitignore).
# En Streamlit Cloud pegas su contenido en el panel de Secrets.
# ─────────────────────────────────────────────────────────────

# Pega aquí la "Connection string" de Supabase (modo Transaction/Session)
# Ejemplo real:
# DATABASE_URL = "postgresql://postgres.xxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

DATABASE_URL = "postgresql://postgres.TUPROYECTO:TUPASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
